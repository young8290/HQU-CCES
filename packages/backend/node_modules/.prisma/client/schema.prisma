// Prisma Schema for 综测管理系统
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("monitor") // "admin" | "monitor"
  classId      Int?     @map("class_id")
  displayName  String?  @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  class      Class?      @relation(fields: [classId], references: [id], onDelete: SetNull)
  scores     Score[]     @relation("UpdatedBy")
  importLogs ImportLog[]

  @@map("users")
}

model Grade {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  classes Class[]

  @@map("grades")
}

model Class {
  id        Int      @id @default(autoincrement())
  gradeId   Int      @map("grade_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  grade    Grade     @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  students Student[]
  users    User[]

  @@unique([gradeId, name])
  @@map("classes")
}

model Student {
  id        Int      @id @default(autoincrement())
  studentNo String   @unique @map("student_no")
  name      String
  classId   Int      @map("class_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  class  Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  scores Score[]

  @@map("students")
}

model AcademicYear {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")

  scores Score[]

  @@map("academic_years")
}

model Score {
  id             Int      @id @default(autoincrement())
  studentId      Int      @map("student_id")
  academicYearId Int      @map("academic_year_id")
  category       String // moral, academic, innovation, sports_base, sports_reward, sports_total, aesthetics, labor, public_service, bonus, total
  value          Float    @default(0)
  remark         String?
  updatedBy      Int?     @map("updated_by")
  updatedAt      DateTime @updatedAt @map("updated_at")

  student       Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  updatedByUser User?        @relation("UpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([studentId, academicYearId, category])
  @@map("scores")
}

model ImportLog {
  id           Int      @id @default(autoincrement())
  type         String // academic, sports, personal_form
  filename     String?
  successCount Int      @default(0) @map("success_count")
  failCount    Int      @default(0) @map("fail_count")
  failDetails  String?  @map("fail_details") // JSON string
  importedBy   Int?     @map("imported_by")
  createdAt    DateTime @default(now()) @map("created_at")

  importedByUser User? @relation(fields: [importedBy], references: [id], onDelete: SetNull)

  @@map("import_logs")
}
