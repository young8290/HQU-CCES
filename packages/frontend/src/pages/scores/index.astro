---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="分数填写 - 综测管理系统">
  <div class="flex h-screen bg-neutral-50 dark:bg-neutral-950">
    <div id="sidebar-root"></div>
    <main class="flex-1 overflow-auto">
      <div class="p-6 lg:p-8 max-w-7xl mx-auto">
        <div id="scores-root"></div>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { isLoggedIn } from '../../lib/auth';
  if (!isLoggedIn()) window.location.href = '/login';
</script>

<script>
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import Sidebar from '../../components/layout/Sidebar';
  import ScoresPage from '../../components/scores/ScoresPage';

  const sidebarEl = document.getElementById('sidebar-root');
  if (sidebarEl) createRoot(sidebarEl).render(createElement(Sidebar, { currentPath: '/scores' }));

  const mainEl = document.getElementById('scores-root');
  if (mainEl) createRoot(mainEl).render(createElement(ScoresPage));
</script>
