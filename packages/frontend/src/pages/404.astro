---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 - 页面未找到">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-orange-50 to-amber-50 dark:from-neutral-900 dark:to-neutral-800">
    <div class="text-center p-8">
      <h1 class="text-8xl font-bold text-orange-500 mb-4">404</h1>
      <p class="text-2xl text-neutral-700 dark:text-neutral-300 mb-8">页面未找到</p>
      <p class="text-neutral-500 dark:text-neutral-400 mb-8">您访问的页面不存在或已被移除</p>
      <a
        href="/login"
        class="inline-block px-6 py-3 bg-orange-500 hover:bg-orange-600 text-white rounded-2xl font-medium transition-colors"
      >
        返回首页
      </a>
    </div>
  </div>
</Layout>
