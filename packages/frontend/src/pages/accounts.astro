---
import Layout from '../layouts/Layout.astro';
---
<Layout title="账号管理 - 综测管理系统">
  <div class="flex h-screen bg-neutral-50 dark:bg-neutral-950">
    <div id="sidebar-root"></div>
    <main class="flex-1 overflow-auto">
      <div class="p-6 lg:p-8 max-w-6xl mx-auto">
        <div id="accounts-root"></div>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { isLoggedIn, getUser } from '../lib/auth';
  if (!isLoggedIn()) window.location.href = '/login';
  const user = getUser();
  if (user?.role !== 'admin') window.location.href = '/dashboard';
</script>

<script>
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import Sidebar from '../components/layout/Sidebar';
  import AccountsPage from '../components/accounts/AccountsPage';

  const sidebarEl = document.getElementById('sidebar-root');
  if (sidebarEl) createRoot(sidebarEl).render(createElement(Sidebar, { currentPath: '/accounts' }));

  const mainEl = document.getElementById('accounts-root');
  if (mainEl) createRoot(mainEl).render(createElement(AccountsPage));
</script>
