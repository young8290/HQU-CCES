---
import Layout from '../layouts/Layout.astro';
---

<Layout title="综测填写系统">
  <div id="app-root"></div>
  <script>
    // Redirect based on auth state
    const token = localStorage.getItem('token');
    if (token) {
      window.location.href = '/dashboard';
    } else {
      window.location.href = '/login';
    }
  </script>
</Layout>
